# ----------------------------
# Docker / Compose
# ----------------------------
POSTGRES_VERSION=16-alpine
REDIS_VERSION=7-alpine

# ----------------------------
# PostgreSQL
# ----------------------------
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----------------------------
# Django
# ----------------------------
SECRET_KEY=django-insecure-local-dev-key-change-me
DEBUG=1
DB_ENGINE=postgres
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=1
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0
CELERY_TASK_EAGER_PROPAGATES=0

# SMTP relay (Port 587, no auth by default)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail-relay
EMAIL_PORT=587
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_TIMEOUT=10
TEST_RESULTS_EMAIL_ENABLED=1
TEST_RESULTS_EMAIL_RECIPIENTS=jdienst@beckerccc.com
TEST_RESULTS_EMAIL_SUBJECT_PREFIX=[pytest]
# Optional override if git metadata is unavailable in container
TEST_RESULTS_EMAIL_BRANCH=
TEST_RESULTS_EMAIL_COMMIT=

# ----------------------------
# Auth / JWT
# ----------------------------
# Access token lifetime in minutes
AUTH_ACCESS_TOKEN_LIFETIME_MINUTES=10
# Refresh token lifetime in days
AUTH_REFRESH_TOKEN_LIFETIME_DAYS=14
# JWT signing algorithm
AUTH_JWT_ALGORITHM=HS256
# Optional: set custom signing key (if empty, SECRET_KEY is used)
AUTH_JWT_SIGNING_KEY=
# Optional for asymmetric JWT (e.g. RS256/ES256)
AUTH_JWT_VERIFYING_KEY=
# Optional claims hardening
AUTH_JWT_AUDIENCE=
AUTH_JWT_ISSUER=
# Optional remote JWKS URL for key distribution
AUTH_JWT_JWK_URL=
# Set 0 for pure API deployments without SessionAuthentication
AUTH_API_ENABLE_SESSION_AUTH=1

# Refresh cookie settings
AUTH_REFRESH_COOKIE_NAME=refresh_token
# In local HTTP development often set to 0; in production over HTTPS keep 1
AUTH_REFRESH_COOKIE_SECURE=1
AUTH_REFRESH_COOKIE_HTTPONLY=1
AUTH_REFRESH_COOKIE_SAMESITE=Lax
# Optional: set cookie domain for shared subdomains
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/api/auth/
AUTH_REFRESH_COOKIE_MAX_AGE_SECONDS=1209600

# Auth endpoint throttling
AUTH_LOGIN_RATE=10/minute
AUTH_REFRESH_RATE=30/hour
AUTH_LOGOUT_RATE=60/hour
NOTIFICATION_CREATE_RATE=120/hour
NOTIFICATION_MARK_READ_RATE=240/hour
NOTIFICATION_PREFERENCE_UPDATE_RATE=120/hour
NOTIFICATION_DIGEST_WINDOW_MINUTES=60
NOTIFICATION_DELIVERY_CRON_SECONDS=15
NOTIFICATION_DIGEST_BUILD_CRON_SECONDS=300
NOTIFICATION_DIGEST_DISPATCH_CRON_SECONDS=300

# Port published on host machine
BACKEND_PORT=8000

# ----------------------------
# Frontend / Next.js
# ----------------------------
FRONTEND_HOSTNAME=0.0.0.0
FRONTEND_PORT=3000
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
